# Environment variables for the project

# === API Keys for Google Gemini (get from https://aistudio.google.com/apikey) ===
# General API key (optional, used as fallback)
GEMINI_API_KEY=your_gemini_api_key_here

# Separate API keys for Generator and Judge (recommended to double rate limits)
# If you don't have separate keys, set these to the same as GEMINI_API_KEY
GEMINI_API_KEY_GENERATOR=your_generator_api_key_here
GEMINI_API_KEY_JUDGE=your_judge_api_key_here

# === Configuration ===
# Set to "true" to enable LLM-based pictogram selection (uses Gemini)
# Set to "false" to use only embedding-based selection (no LLM tokens used)
USE_LLM_GENERATOR=false  # Change to true when you have API keys configured

# === Instructions ===
# 1. Copy this file to .env:  cp .env.example .env
# 2. Fill in your API keys from Google AI Studio
# 3. Set USE_LLM_GENERATOR=true when ready to use LLM features
# 4. Docker Compose will automatically load these variables
